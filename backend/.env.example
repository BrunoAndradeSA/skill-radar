# App
APP_NAME=Skill Radar
APP_ENV=development
API_V1_PREFIX=/api/v1

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=skill_radar
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=20

# HTTP Log
HTTP_LOG_CAPTURE_RESPONSE_BODY=true
HTTP_LOG_MAX_BODY_SIZE=10000

# Feature Flags
ENABLE_MOCK_MODE=false
ENABLE_AUTHENTICATION=true
ENABLE_EMAIL_SENDING=true
ENABLE_FOCUS_MONITORING=true
ENABLE_AUTO_TERMINATION=true
ENABLE_AUDIT_LOG=true

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_TOKEN=5/minute
RATE_LIMIT_REFRESH=10/minute
